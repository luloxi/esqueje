# Esqueje Agent Configuration

# Required: Cardano wallet mnemonic (24 words)
ESQUEJE_MNEMONIC="word1 word2 word3 ... word24"

# Required: Cardano network (mainnet, preprod, preview)
CARDANO_NETWORK=preprod

# Required: Blockfrost API key
BLOCKFROST_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: Creator address for attribution
CREATOR_ADDRESS=addr1...

# Optional: Agent name
ESQUEJE_NAME=Esqueje

# Optional: Genesis prompt (defines agent personality)
GENESIS_PROMPT="I am Esqueje, an autonomous AI agent on Cardano..."

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Heartbeat interval in milliseconds
HEARTBEAT_INTERVAL_MS=60000

# ============================================
# TELEGRAM INTEGRATION (Optional but recommended)
# ============================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# Comma-separated list of allowed chat IDs
TELEGRAM_CHAT_IDS=123456789,987654321

# ============================================
# TREASURY CONFIGURATION (Optional)
# ============================================

MONTHLY_HOSTING_ADA=25
MONTHLY_OPERATIONS_ADA=5
TARGET_MONTHLY_PROFIT_ADA=15
MIN_AGENT_BALANCE_ADA=500
REPLICATION_SEED_ADA=500
MAX_TRADE_ALLOCATION_PCT=0.12
